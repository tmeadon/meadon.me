---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import getReadingTime from "reading-time";
import { toString } from "mdast-util-to-string";
import { fromMarkdown } from "mdast-util-from-markdown";

type Props = CollectionEntry<"blog">;

const {
	title,
	description,
	pubDate,
	updatedDate,
	seriesSlug,
	seriesTitle,
	seriesPart,
	seriesDisclaimer,
} = Astro.props["data"];

const showSeriesInfo = Boolean(seriesSlug);
const showDisclaimer = showSeriesInfo && seriesDisclaimer !== false;

const textOnPage = toString(fromMarkdown(Astro.props.body));
const { text: readingTime, words } = getReadingTime(textOnPage);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description ?? ""} />
		<style>
			main {
				width: 100%;
				margin: 0;
			}
			.prose {
				max-width: 900px;
				margin: 60px auto 0;
				padding: 0 64px;
			}

			.prose .title h1 {
				text-align: center;
				font-size: 32px;
				font-weight: 400;
				line-height: 48px;
			}

			.prose .tip {
				text-align: center;
				color: #8c8c8c;
				margin-top: 18px;
				font-size: 14px;
			}

			.prose .tip .split {
				margin: 0 4px;
			}

			.prose .content {
				margin-top: 36px;
			}

			.prose .series {
				text-align: center;
				margin-top: 18px;
				font-size: 14px;
				color: #757575;
			}

			.prose .series a {
				color: #0366d6;
			}

			.prose .disclaimer {
				margin: 28px auto 0;
				padding: 16px 18px;
				border-left: 4px solid #d0d7de;
				background: #f6f8fa;
				color: #555;
				font-size: 14px;
				line-height: 1.6;
			}

			.prose .tags {
				margin-top: 24px;
			}

			.prose .tags a {
				background: #f2f2f2;
				padding: 4px 7px;
				color: #757575;
				font-size: 14px;
				margin-right: 3px;
			}

			.prose .tags a:hover {
				color: #0366d6;
			}

			@media (max-width: 700px) {
				.prose {
					padding: 0 10px;
					margin: 20px auto 0;
				}

				.prose .title h1 {
					font-size: 24px;
					line-height: 32px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
				<div class="title">
					<h1>{title}</h1>
				</div>
				{showSeriesInfo && (
					<div class="series">
						<a href={`/blog/${seriesSlug}/`}>
							{seriesTitle ?? seriesSlug}
						</a>
						{seriesPart && <span> · Part {seriesPart}</span>}
					</div>
				)}
				<div class="tip">
					<FormattedDate date={pubDate} />
						<span class="split"> · </span>
						<span> {words} words </span>
						<span class="split"> · </span>
						<span> {readingTime}</span>
						<span class="split"> · </span>
						{
							updatedDate && (
								<div class="last-updated-on">
									Last updated on{" "}
									<FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
				<div class="content">
					{showDisclaimer && (
						<div class="disclaimer">
							This article was drafted with help from ChatGPT as part of a
							transparent writing process. I reviewed, edited, and own the
							final piece. If I publish a manually written article in this
							series, I can switch this notice off for that post.
						</div>
					)}
					<slot />
				</div>
			</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
